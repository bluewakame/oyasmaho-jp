# この例ファイルをコピーして「.env.local」という名前で保存してください。
# .env.local は .gitignore で除外されているので、GitHubに上がりません。

# --- サイト設定 ---
# 本番のサイトURL（Vercelデプロイ後のドメインに書き換える）
NEXT_PUBLIC_SITE_URL=https://example.com

# --- Google Analytics 4 ---
# まだ取得していなければ空のままでもOK。空なら計測タグは出力されません。
# 例: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# --- Google AdSense ---
# 審査通過後に設定（pub-XXXXXXXXXXXXXXXX の形式）。空なら何も出力されません。
NEXT_PUBLIC_ADSENSE_CLIENT=
